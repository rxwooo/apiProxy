# Local proxy
LOCAL_HOST=127.0.0.1
LOCAL_PORT=8787
RELAY_URL=wss://relay.example.com/relay
RELAY_TOKEN=change-me

# Remote relay
RELAY_HOST=0.0.0.0
RELAY_PORT=8788
RELAY_PATH=/relay
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=sk-change-me
UPSTREAM_AUTH_SCHEME=Bearer
MODEL_ID_MAP={"A":"provider-real-model-id"}

# Shared limits
CHUNK_SIZE=8192
REQUEST_TIMEOUT_MS=120000
RELAY_CONNECT_TIMEOUT_MS=5000
HEARTBEAT_INTERVAL_MS=30000
MAX_REQUEST_BYTES=10485760
MAX_RESPONSE_BYTES=52428800
MAX_CONCURRENT_REQUESTS=32
LOG_LEVEL=info
