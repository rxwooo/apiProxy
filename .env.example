# Local proxy
LOCAL_HOST=127.0.0.1
LOCAL_PORT=8787
RELAY_URL=wss://relay.example.com/relay
RELAY_TOKEN=change-me
# Application-layer relay encryption. Use required in inspected proxy environments.
# Generate a PSK with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
RELAY_E2EE=off
# RELAY_E2EE_KEY_ID=main
# RELAY_E2EE_PSK_B64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Optional explicit proxy for the local client's outbound WSS relay connection.
# Useful when Windows/browser PAC can reach the relay but Node.js direct WSS cannot.
RELAY_PROXY=
RELAY_NO_PROXY=localhost,127.0.0.1

# Remote relay
RELAY_HOST=0.0.0.0
RELAY_PORT=8788
RELAY_PATH=/relay
# Remote relay can use RELAY_E2EE_PSK_B64 with RELAY_E2EE_KEY_ID for one key,
# or RELAY_E2EE_KEYS_JSON for rotation with multiple accepted key ids.
# RELAY_E2EE_KEYS_JSON={"main":"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="}
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=sk-change-me
UPSTREAM_AUTH_SCHEME=Bearer
MODEL_ID_MAP={"A":"provider-real-model-id"}

# Shared limits
CHUNK_SIZE=8192
REQUEST_TIMEOUT_MS=120000
RELAY_CONNECT_TIMEOUT_MS=5000
HEARTBEAT_INTERVAL_MS=30000
MAX_REQUEST_BYTES=10485760
MAX_RESPONSE_BYTES=52428800
MAX_CONCURRENT_REQUESTS=32
LOG_LEVEL=info
